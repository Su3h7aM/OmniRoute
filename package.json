{
	"name": "omniroute",
	"version": "3.6.9",
	"description": "Smart AI Router with auto fallback \u2014 route to FREE & cheap models, zero downtime. Works with Cursor, Cline, Claude Desktop, Codex, and any OpenAI-compatible tool.",
	"type": "module",
	"files": [
		"app/",
		"open-sse/mcp-server/index.ts",
		"open-sse/mcp-server/server.ts",
		"open-sse/mcp-server/httpTransport.ts",
		"open-sse/mcp-server/audit.ts",
		"open-sse/mcp-server/runtimeHeartbeat.ts",
		"open-sse/mcp-server/scopeEnforcement.ts",
		"open-sse/mcp-server/schemas/",
		"open-sse/mcp-server/tools/",
		"open-sse/mcp-server/README.md",
		"src/shared/contracts/",
		".env.example",
		"scripts/postinstall.ts",
		"scripts/postinstallSupport.ts",
		"scripts/sync-env.ts",
		"scripts/build-next-isolated.ts",
		"README.md",
		"LICENSE"
	],
	"workspaces": ["open-sse"],
	"packageManager": "bun@1.3.12",
	"engines": {
		"bun": ">=1.3.12"
	},
	"keywords": [
		"ai",
		"router",
		"proxy",
		"openai",
		"claude",
		"anthropic",
		"gemini",
		"fallback",
		"cursor",
		"cline",
		"codex",
		"llm",
		"auto-fallback"
	],
	"license": "MIT",
	"author": "diegosouzapw",
	"repository": {
		"type": "git",
		"url": "https://github.com/diegosouzapw/OmniRoute"
	},
	"homepage": "https://omniroute.online",
	"scripts": {
		"dev": "bun scripts/run-next.ts dev",
		"build": "bun scripts/build-next-isolated.ts",
		"start": "bun scripts/run-next.ts start",
		"postinstall": "bun scripts/postinstall.ts",
		"env:sync": "bun scripts/sync-env.ts",

		"format": "biome format --write .",
		"check:format": "biome format .",
		"check:lint": "biome check .",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"lint:unsafe": "biome check . --write --unsafe",
		"typecheck:core": "tsgo --pretty false -p tsconfig.typecheck-core.json",
		"typecheck:noimplicit:core": "tsgo --pretty false -p tsconfig.typecheck-noimplicit-core.json",

		"test": "bun run test:unit",
		"test:unit": "bun test --env-file=.env.test --parallel 1 ./tests/unit",
		"test:integration": "bun test --env-file=.env.test --parallel 1 ./tests/integration",
		"test:mcp-services": "bun test --env-file=.env.test --parallel 1 open-sse/mcp-server/__tests__ open-sse/services/autoCombo/__tests__ open-sse/services/__tests__",
		"test:e2e:protocols": "bun test --env-file=.env.test --parallel 1 ./tests/e2e/protocol-clients.test.ts",
		"test:e2e:ecosystem": "bun test --env-file=.env.test --parallel 1 ./tests/e2e/ecosystem.test.ts",
		"test:plan3": "bun test --env-file=.env.test --parallel 1 ./tests/unit/plan3-p0.test.ts",
		"test:fixes": "bun test --env-file=.env.test --parallel 1 ./tests/unit/fixes-p1.test.ts",
		"test:security": "bun test --env-file=.env.test --parallel 1 ./tests/unit/security-fase01.test.ts",
		"test:all": "bun run test:unit && bun run test:mcp-services && bun run test:integration && bun run test:e2e:ecosystem && bun run test:e2e:protocols",

		"coverage": "bun test --env-file=.env.test --coverage --parallel 1 ./tests/unit",
		"coverage:report": "c8 report --output-dir coverage --exclude=tests/** --exclude=**/*.test.* --reporter=text --reporter=text-summary --reporter=html --reporter=json-summary --reporter=lcov",
		"coverage:summary": "bun scripts/test-report-summary.ts --input coverage/coverage-summary.json --output coverage/coverage-report.md --threshold 60",

		"verify:cycles": "bun scripts/check-cycles.ts",
		"verify:route-validation:t06": "bun scripts/check-route-validation.ts",
		"verify:any-budget:t11": "bun scripts/check-t11-any-budget.ts",
		"verify:docs-sync": "bun scripts/check-docs-sync.ts",
		"verify:pack-artifact": "bun scripts/validate-pack-artifact.ts",
		"verify:pr-test-policy": "bun scripts/check-pr-test-policy.ts",
		"check": "bun run lint && bun run test"
	},
	"dependencies": {
		"@lobehub/icons": "^5.0.1",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@monaco-editor/react": "^4.7.0",
		"@swc/helpers": "0.5.21",
		"bcryptjs": "^3.0.3",
		"bottleneck": "^2.19.5",
		"dompurify": "^3.4.0",
		"jose": "^6.1.3",
		"js-yaml": "^4.1.0",
		"monaco-editor": "^0.55.1",
		"netbun": "^0.2.3",
		"next": "^16.2.3",
		"next-intl": "^4.8.3",
		"open": "^11.0.0",
		"ora": "^9.1.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"recharts": "^3.7.0",
		"selfsigned": "^5.5.0",
		"tsx": "^4.21.0",
		"uuid": "^13.0.0",
		"wreq-js": "^2.0.1",
		"xxhash-wasm": "^1.1.0",
		"yazl": "^3.3.1",
		"zod": "^4.3.6",
		"zustand": "^5.0.10"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@happy-dom/global-registrator": "^20.0.5",
		"@tailwindcss/postcss": "^4.1.18",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/bcryptjs": "^3.0.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260418.1",
		"@vitejs/plugin-react": "^6.0.1",
		"bun-types": "^1.3.12",
		"c8": "^11.0.0",
		"prop-types": "^15.8.1",
		"tailwindcss": "^4",
		"typescript": "^6.0.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@parcel/watcher", "@swc/core", "esbuild", "omniroute", "sharp"]
	},
	"overrides": {
		"lodash-es": "^4.18.1",
		"dompurify": "^3.4.0",
		"path-to-regexp": "^8.4.0",
		"hono": "^4.12.14",
		"react": "$react",
		"react-dom": "$react-dom"
	}
}
